{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "MCaml",
  "scopeName": "source.mcaml",
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#type-def" },
    { "include": "#function-def" },
    { "include": "#keyword" },
    { "include": "#type" },
    { "include": "#tyvar" },
    { "include": "#constant" },
    { "include": "#constructor" },
    { "include": "#selector" },
    { "include": "#number" },
    { "include": "#operator" },
    { "include": "#wildcard" },
    { "include": "#field-access" },
    { "include": "#function-call" },
    { "include": "#identifier" }
  ],
  "repository": {
    "comment": {
      "name": "comment.block.mcaml",
      "begin": "\\(\\*",
      "end": "\\*\\)",
      "patterns": [{ "include": "#comment" }]
    },
    "string": {
      "name": "string.quoted.double.mcaml",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.mcaml", "match": "\\\\(/|\"|\\\\|b|f|n|r|t)" }
      ]
    },
    "type-def": {
      "match": "\\b(type)\\s+([a-z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.other.mcaml" },
        "2": { "name": "entity.name.type.mcaml" }
      }
    },
    "function-def": {
      "match": "\\b(fun)\\s+([a-z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.other.mcaml" },
        "2": { "name": "entity.name.function.mcaml" }
      }
    },
    "keyword": {
      "patterns": [
        {
          "name": "keyword.control.mcaml",
          "match": "\\b(if|then|else|match|with|for|to|do|done)\\b"
        },
        {
          "name": "keyword.other.mcaml",
          "match": "\\b(let|in|fun|val|ref|type|of|region)\\b"
        },
        {
          "name": "keyword.other.command.mcaml",
          "match": "\\bcmd!"
        }
      ]
    },
    "type": {
      "name": "support.type.mcaml",
      "match": "\\b(int|float|bool|unit|sel|pos|arr|mat|list|darr)\\b"
    },
    "tyvar": {
      "name": "support.type.type-variable.mcaml",
      "match": "'[a-zA-Z0-9_]+"
    },
    "constant": {
      "name": "constant.language.mcaml",
      "match": "\\b(true|false)\\b"
    },
    "constructor": {
      "name": "entity.name.type.constructor.mcaml",
      "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
    },
    "selector": {
      "name": "variable.language.selector.mcaml",
      "match": "@[aeprs](\\[[^\\]]*\\])?"
    },
    "number": {
      "patterns": [
        { "name": "constant.numeric.float.mcaml", "match": "\\b[0-9]+\\.[0-9]*" },
        { "name": "constant.numeric.integer.mcaml", "match": "\\b[0-9]+\\b" }
      ]
    },
    "operator": {
      "patterns": [
        { "name": "keyword.operator.arrow.mcaml", "match": "->" },
        { "name": "keyword.operator.assignment.mcaml", "match": ":=" },
        { "name": "keyword.operator.cons.mcaml", "match": "::" },
        { "name": "keyword.operator.comparison.mcaml", "match": "<=|>=|!=|<|>" },
        { "name": "keyword.operator.logical.mcaml", "match": "&&|\\|\\||!" },
        { "name": "keyword.operator.pipe.mcaml", "match": "\\|>" },
        { "name": "keyword.operator.arithmetic.float.mcaml", "match": "\\+\\.|-\\.|\\*\\.|/\\." },
        { "name": "keyword.operator.arithmetic.mcaml", "match": "\\+|-|\\*|/|%" },
        { "name": "keyword.operator.assignment.mcaml", "match": "=" },
        { "name": "keyword.operator.match-arm.mcaml", "match": "\\|(?![\\]|])" },
        { "name": "keyword.operator.coord.mcaml", "match": "~|\\^" }
      ]
    },
    "wildcard": {
      "name": "constant.language.wildcard.mcaml",
      "match": "(?<![a-zA-Z0-9_])_(?![a-zA-Z0-9_])"
    },
    "field-access": {
      "match": "(?<=\\.)([a-z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "variable.other.member.mcaml" }
      }
    },
    "function-call": {
      "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.call.mcaml" }
      }
    },
    "identifier": {
      "name": "variable.other.mcaml",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    }
  }
}
