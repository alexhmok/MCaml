{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "MCaml",
  "scopeName": "source.mcaml",
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#keyword" },
    { "include": "#type" },
    { "include": "#constant" },
    { "include": "#selector" },
    { "include": "#number" },
    { "include": "#operator" },
    { "include": "#function-def" },
    { "include": "#function-call" },
    { "include": "#identifier" }
  ],
  "repository": {
    "comment": {
      "name": "comment.block.mcaml",
      "begin": "\\(\\*",
      "end": "\\*\\)",
      "patterns": [{ "include": "#comment" }]
    },
    "string": {
      "name": "string.quoted.double.mcaml",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.mcaml", "match": "\\\\(/|\"|\\\\|b|f|n|r|t)" }
      ]
    },
    "keyword": {
      "patterns": [
        {
          "name": "keyword.control.mcaml",
          "match": "\\b(if|then|else|for|to|do|done|in)\\b"
        },
        {
          "name": "keyword.other.mcaml",
          "match": "\\b(let|fun|val|ref)\\b"
        },
        {
          "name": "keyword.other.command.mcaml",
          "match": "\\bcmd!"
        }
      ]
    },
    "type": {
      "name": "support.type.mcaml",
      "match": "\\b(int|bool|unit|sel|pos|arr|mat)\\b"
    },
    "constant": {
      "name": "constant.language.mcaml",
      "match": "\\b(true|false)\\b"
    },
    "selector": {
      "name": "variable.language.selector.mcaml",
      "match": "@[aeprs](\\[[^\\]]*\\])?"
    },
    "number": {
      "patterns": [
        { "name": "constant.numeric.float.mcaml", "match": "\\b-?[0-9]+\\.[0-9]*" },
        { "name": "constant.numeric.integer.mcaml", "match": "\\b-?[0-9]+\\b" }
      ]
    },
    "operator": {
      "patterns": [
        { "name": "keyword.operator.assignment.mcaml", "match": ":=|=" },
        { "name": "keyword.operator.comparison.mcaml", "match": "<=|>=|!=|<|>" },
        { "name": "keyword.operator.logical.mcaml", "match": "&&|\\|\\||!" },
        { "name": "keyword.operator.pipe.mcaml", "match": "\\|>" },
        { "name": "keyword.operator.arithmetic.mcaml", "match": "\\+|-|\\*|/" },
        { "name": "keyword.operator.coord.mcaml", "match": "~|\\^" }
      ]
    },
    "function-def": {
      "match": "\\b(let)\\s+(rec\\s+)?([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=[a-zA-Z_(])",
      "captures": {
        "1": { "name": "keyword.other.mcaml" },
        "3": { "name": "entity.name.function.mcaml" }
      }
    },
    "function-call": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.call.mcaml" }
      }
    },
    "identifier": {
      "name": "variable.other.mcaml",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    }
  }
}
