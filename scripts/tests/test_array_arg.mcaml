(* test_array_arg.mcaml — first-class array parameters via monomorphization. *)
fun dot(a: arr[int, 4], b: arr[int, 4]): int =
  let r = ref 0 in
  for i = 0 to 4 do
    r := !r + a[i] * b[i]
  done;
  !r

fun run(x: int): int =
  let u = [| 1; 2; 3; 4 |] in
  let v = [| 5; 6; 7; 8 |] in
  dot(u, v)
